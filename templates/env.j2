TZ={{ mobilizon_environment_variables_tz }}

{#
  See: https://framagit.org/kaihuri/mobilizon-docker/-/blob/master/env.template
#}

MOBILIZON_INSTANCE_NAME={{ mobilizon_environment_variables_instance_name }}
MOBILIZON_INSTANCE_HOST={{ mobilizon_hostname }}
MOBILIZON_INSTANCE_PORT={{ mobilizon_container_http_port }}

MOBILIZON_INSTANCE_REGISTRATIONS_OPEN={{ mobilizon_environment_variables_registrations_open | to_json }}

MOBILIZON_INSTANCE_EMAIL={{ mobilizon_environment_variables_instance_email }}
MOBILIZON_REPLY_EMAIL={{ mobilizon_environment_variables_email_reply_email }}

MOBILIZON_LOGLEVEL={{ mobilizon_environment_variables_loglevel }}

MOBILIZON_DATABASE_HOST={{ mobilizon_database_hostname }}
MOBILIZON_DATABASE_PORT={{ mobilizon_database_port }}
MOBILIZON_DATABASE_USERNAME={{ mobilizon_database_username }}
MOBILIZON_DATABASE_PASSWORD={{ mobilizon_database_password}}
MOBILIZON_DATABASE_SSL={{ mobilizon_database_sslmode | to_json }}
MOBILIZON_DATABASE_DBNAME={{ mobilizon_database_name }}

MOBILIZON_INSTANCE_SECRET_KEY_BASE={{ mobilizon_environment_variables_secret_key_base }}
MOBILIZON_INSTANCE_SECRET_KEY={{ mobilizon_environment_variables_secret_key }}

MOBILIZON_SMTP_SERVER={{ mobilizon_environment_variables_email_smtp_server }}
MOBILIZON_SMTP_PORT={{ mobilizon_environment_variables_email_smtp_port }}
MOBILIZON_SMTP_USERNAME={{ mobilizon_environment_variables_email_smtp_username }}
MOBILIZON_SMTP_PASSWORD={{ mobilizon_environment_variables_email_smtp_password }}
MOBILIZON_SMTP_SSL={{ mobilizon_environment_variables_email_smtp_ssl | to_json }}
MOBILIZON_SMTP_TLS={{ mobilizon_environment_variables_email_smtp_tls }}

{{ mobilizon_environment_variables_additional_variables }}
